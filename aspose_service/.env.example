ASPOSE_SERVICE_UPLOAD_DIR=runtime/uploads
ASPOSE_SERVICE_OUTPUT_DIR=runtime/outputs
ASPOSE_SERVICE_MAX_UPLOAD_BYTES=52428800
# ASPOSE_SERVICE_ASPOSE_LICENSE_PATH=/absolute/path/to/Aspose.Total.Python.NET.lic
# Optional: point each worker at an isolated Python environment.
# This is useful when Aspose product packages conflict through shared native modules.
# ASPOSE_SERVICE_WORD_PYTHON=/opt/aspose-word/.venv/bin/python
# ASPOSE_SERVICE_CELLS_PYTHON=/opt/aspose-cells/.venv/bin/python
# ASPOSE_SERVICE_SLIDES_PYTHON=/opt/aspose-slides/.venv/bin/python
# ASPOSE_SERVICE_EMAIL_PYTHON=/opt/aspose-email/.venv/bin/python
# Optional: directory containing compatibility native libraries such as libssl.so.1.1.
# ASPOSE_SERVICE_WORKER_LIBRARY_PATH=/absolute/path/to/runtime/compat/openssl1.1/usr/lib/x86_64-linux-gnu
